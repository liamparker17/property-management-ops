# .env.example
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
DIRECT_URL="postgres://user:pass@host/db?sslmode=require"

NEXTAUTH_SECRET="replace-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

SENTRY_DSN=""
EXPIRING_WINDOW_DAYS="60"

# Gmail SMTP — transactional email (via nodemailer)
# Requires 2-Step Verification on the Google account, then generate an App Password:
# https://myaccount.google.com/apppasswords
# Leave blank to disable email sending (PM still sees temp password in UI).
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Display name used in the From header (default: "PMOps")
EMAIL_FROM_NAME="PMOps"
# Optional: explicit From header override (default: "EMAIL_FROM_NAME <GMAIL_USER>")
EMAIL_FROM=""
# Optional: where replies should go (leave blank for true no-reply). Example: "Support <support@yourdomain.co.za>".
EMAIL_REPLY_TO=""
# Base URL used in email links (e.g. the login page). Defaults to request host; override if needed.
APP_URL="http://localhost:3000"
