# .env.example
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
DIRECT_URL="postgres://user:pass@host/db?sslmode=require"

NEXTAUTH_SECRET="replace-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

SENTRY_DSN=""
EXPIRING_WINDOW_DAYS="60"

# Resend — transactional email (free tier: 3000/mo, 100/day)
# Get key at https://resend.com/api-keys. Leave blank to disable email sending (PM still sees temp password in UI).
RESEND_API_KEY=""
# Sender address. For testing without domain verification use "onboarding@resend.dev" (only delivers to your Resend account email).
# For production: set to a verified domain, e.g. "PMOps <noreply@yourdomain.co.za>"
EMAIL_FROM="PMOps <onboarding@resend.dev>"
# Optional: where replies should go (leave blank for true no-reply). Example: "Support <support@yourdomain.co.za>".
EMAIL_REPLY_TO=""
# Base URL used in email links (e.g. the login page). Defaults to request host; override if needed.
APP_URL="http://localhost:3000"
