# .env.example
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"
DIRECT_URL="postgres://user:pass@host/db?sslmode=require"

NEXTAUTH_SECRET="replace-me-openssl-rand-base64-32"
NEXTAUTH_URL="https://regalis.co.za"

BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

SENTRY_DSN=""
EXPIRING_WINDOW_DAYS="60"

# SMTP / email
# Use SMTP_* for a shared mail transport, then route specific email types through
# the named mailboxes below. This works well for custom-domain addresses like
# updates@regalis.co.za and noreply@regalis.co.za.
# Example providers:
# - Google Workspace / Gmail: smtp.gmail.com / 587 / false
# - Microsoft 365: smtp.office365.com / 587 / false
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
# Display name used in the default From header (default: "Regalis")
EMAIL_FROM_NAME="Regalis"
# Optional: explicit default From header override (default: "EMAIL_FROM_NAME <SMTP_USER>")
EMAIL_FROM=""
# Optional: default reply-to for general mail.
EMAIL_REPLY_TO=""
# Mailbox used for system / transactional email such as tenant invites.
EMAIL_NOREPLY_FROM="Regalis <noreply@regalis.co.za>"
EMAIL_NOREPLY_REPLY_TO="Updates <updates@regalis.co.za>"
# Optional: only set these if the noreply mailbox has its own SMTP login.
EMAIL_NOREPLY_SMTP_HOST=""
EMAIL_NOREPLY_SMTP_PORT=""
EMAIL_NOREPLY_SMTP_SECURE=""
EMAIL_NOREPLY_SMTP_USER=""
EMAIL_NOREPLY_SMTP_PASSWORD=""
# Mailbox used for public contact, signup requests, and ops-style alerts.
EMAIL_UPDATES_FROM="Regalis Updates <updates@regalis.co.za>"
EMAIL_UPDATES_REPLY_TO="Updates <updates@regalis.co.za>"
# Optional: only set these if the updates mailbox has its own SMTP login.
EMAIL_UPDATES_SMTP_HOST=""
EMAIL_UPDATES_SMTP_PORT=""
EMAIL_UPDATES_SMTP_SECURE=""
EMAIL_UPDATES_SMTP_USER=""
EMAIL_UPDATES_SMTP_PASSWORD=""
# Legacy Gmail fallback. Leave blank if you use SMTP_* above.
# Requires 2-Step Verification on the Google account, then generate an App Password:
# https://myaccount.google.com/apppasswords
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Base URL used in email/SMS links (e.g. the login page). Defaults to request host; override if needed.
APP_URL="https://regalis.co.za"

# SMS Gateway for Android - https://sms-gate.app (cloud mode)
# Install the Android app, toggle Cloud Server on, copy username/password.
# Leave blank to disable SMS sending.
SMS_GATEWAY_USER=""
SMS_GATEWAY_PASSWORD=""
# Optional: override for self-hosted / private server mode (see POPIA note in lib/sms.ts).
# Defaults to https://api.sms-gate.app/3rdparty/v1/message
SMS_GATEWAY_URL=""
# Comma-separated E.164 numbers that receive PM-side alerts
# (new maintenance tickets, lease signings, clause review requests).
# Example: "+27821234567,+27839876543"
OPS_SMS_RECIPIENTS=""
# Comma-separated addresses that receive public-site contact + signup notifications.
# Falls back to the updates mailbox when left blank.
OPS_EMAIL_RECIPIENTS="updates@regalis.co.za"
