generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum Role {
  ADMIN
  PROPERTY_MANAGER
  FINANCE
  TENANT
  LANDLORD
  MANAGING_AGENT
}

enum OrgOwnerType {
  PM_AGENCY
  LANDLORD_DIRECT
}

enum FeatureFlagKey {
  UTILITIES_BILLING
  TRUST_ACCOUNTING
  AREA_NOTICES
  LANDLORD_APPROVALS
  USAGE_ALERTS
  PAYMENT_ALERTS
  ANNUAL_PACKS
}

enum ApprovalKind {
  MAINTENANCE_COMMIT
  LEASE_CREATE
  LEASE_RENEW
  RENT_CHANGE
  TENANT_EVICT
  PROPERTY_REMOVE
}

enum ApprovalState {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

enum LeaseState {
  DRAFT
  ACTIVE
  TERMINATED
  RENEWED
}

enum ApplicationStage {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  VETTING
  APPROVED
  DECLINED
  CONVERTED
  WITHDRAWN
}

enum ApplicationDecision {
  PENDING
  APPROVED
  DECLINED
}

enum TpnCheckStatus {
  NOT_STARTED
  REQUESTED
  RECEIVED
  FAILED
  WAIVED
}

enum TpnRecommendation {
  PASS
  CAUTION
  DECLINE
  UNKNOWN
}

enum DocumentKind {
  LEASE_AGREEMENT
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InvoiceStatus {
  DUE
  PAID
  OVERDUE
}

enum ReviewRequestStatus {
  OPEN
  ACCEPTED
  REJECTED
  RESOLVED
}

enum SAProvince {
  GP
  WC
  KZN
  EC
  FS
  LP
  MP
  NW
  NC
}

// ---------- Org & Auth ----------

model Org {
  id                             String       @id @default(cuid())
  name                           String
  slug                           String       @unique
  ownerType                      OrgOwnerType @default(PM_AGENCY)
  landlordApprovalThresholdCents Int          @default(500000)
  expiringWindowDays             Int          @default(60)
  createdAt                      DateTime     @default(now())

  users               User[]
  properties          Property[]
  units               Unit[]
  tenants             Tenant[]
  leases              Lease[]
  documents           Document[]
  maintenance         MaintenanceRequest[]
  invoices            Invoice[]
  landlords           Landlord[]
  managingAgents      ManagingAgent[]
  approvals           Approval[]
  orgFeatures         OrgFeature[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  applicants          Applicant[]
  applications        Application[]
}

model OrgFeature {
  id        String         @id @default(cuid())
  orgId     String
  key       FeatureFlagKey
  enabled   Boolean        @default(false)
  config    Json?
  updatedAt DateTime       @updatedAt
  org       Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
}

model AuditLog {
  id          String   @id @default(cuid())
  orgId       String
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  diff        Json?
  payload     Json?
  createdAt   DateTime @default(now())
  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId, entityType, entityId])
  @@index([orgId, createdAt])
}

model Landlord {
  id          String    @id @default(cuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id])
  name        String
  email       String?
  phone       String?
  vatNumber   String?
  notes       String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       User[]
  properties  Property[]
  approvals   Approval[]

  @@index([orgId, name])
  @@index([orgId, archivedAt])
}

model ManagingAgent {
  id                 String    @id @default(cuid())
  orgId              String
  org                Org       @relation(fields: [orgId], references: [id])
  name               String
  email              String?
  phone              String?
  notes              String?
  archivedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users              User[]
  assignedProperties Property[]

  @@index([orgId, name])
  @@index([orgId, archivedAt])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String
  role            Role
  orgId           String
  org             Org       @relation(fields: [orgId], references: [id])
  landlordId      String?
  landlord        Landlord?      @relation(fields: [landlordId], references: [id])
  managingAgentId String?
  managingAgent   ManagingAgent? @relation(fields: [managingAgentId], references: [id])
  emailVerified   DateTime?
  image           String?
  disabledAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  uploaded      Document[] @relation("DocumentUploader")
  auditLogs     AuditLog[]
  notifications Notification[]
  assignedApplications Application[] @relation("ApplicationReviewer")
  applicationNotesAuthored ApplicationNote[]

  @@index([orgId])
  @@index([landlordId])
  @@index([managingAgentId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Portfolio ----------

model Property {
  id               String     @id @default(cuid())
  orgId            String
  org              Org        @relation(fields: [orgId], references: [id])
  landlordId       String?
  landlord         Landlord?      @relation(fields: [landlordId], references: [id])
  assignedAgentId  String?
  assignedAgent    ManagingAgent? @relation(fields: [assignedAgentId], references: [id])
  name             String
  addressLine1     String
  addressLine2     String?
  suburb           String
  city             String
  province         SAProvince
  postalCode       String
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  units         Unit[]
  documents     Document[]
  applications  Application[]

  @@index([orgId, name])
  @@index([orgId, deletedAt])
  @@index([landlordId])
  @@index([assignedAgentId])
}

model Unit {
  id          String    @id @default(cuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id])
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  label       String
  bedrooms    Int       @default(0)
  bathrooms   Int       @default(0)
  sizeSqm     Int?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leases      Lease[]
  documents   Document[]
  maintenance MaintenanceRequest[]
  applications Application[]

  @@unique([propertyId, label])
  @@index([orgId, propertyId])
}

model Applicant {
  id                       String    @id @default(cuid())
  orgId                    String
  firstName                String
  lastName                 String
  email                    String
  phone                    String
  idNumber                 String?
  employer                 String?
  grossMonthlyIncomeCents  Int?
  netMonthlyIncomeCents    Int?
  tpnConsentGiven          Boolean   @default(false)
  tpnConsentAt             DateTime?
  tpnConsentCapturedById   String?
  createdAt                DateTime  @default(now())
  org                      Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applications             Application[]

  @@index([orgId, email])
}

model Tenant {
  id          String    @id @default(cuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id])
  firstName   String
  lastName    String
  email       String?
  phone       String?
  idNumber    String?
  notes       String?
  userId      String?   @unique
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  leases      LeaseTenant[]
  documents   Document[]
  maintenance MaintenanceRequest[]
  convertedFromApplication Application? @relation("ConvertedApplication")

  @@index([orgId, email])
  @@index([orgId, archivedAt])
}

model Application {
  id                 String              @id @default(cuid())
  orgId              String
  applicantId        String
  propertyId         String?
  unitId             String?
  requestedMoveIn    DateTime?
  affordabilityRatio Float?
  sourceChannel      String?
  assignedReviewerId String?
  stage              ApplicationStage    @default(DRAFT)
  decision           ApplicationDecision @default(PENDING)
  decisionReason     String?
  decidedAt          DateTime?
  convertedTenantId  String?             @unique
  convertedLeaseId   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  org                Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicant          Applicant           @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  property           Property?           @relation(fields: [propertyId], references: [id])
  unit               Unit?               @relation(fields: [unitId], references: [id])
  reviewer           User?               @relation("ApplicationReviewer", fields: [assignedReviewerId], references: [id])
  convertedTenant    Tenant?             @relation("ConvertedApplication", fields: [convertedTenantId], references: [id])
  tpnCheck           TpnCheck?
  documents          ApplicationDocument[]
  notes              ApplicationNote[]

  @@index([orgId, stage])
}

model TpnCheck {
  id             String            @id @default(cuid())
  applicationId  String            @unique
  status         TpnCheckStatus    @default(NOT_STARTED)
  requestedAt    DateTime?
  receivedAt     DateTime?
  tpnReferenceId String?
  recommendation TpnRecommendation?
  summary        String?
  reportPayload  Json?
  reportBlobKey  String?
  waivedReason   String?
  waivedById     String?
  application    Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  storageKey    String
  filename      String
  mimeType      String
  sizeBytes     Int
  uploadedById  String?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

model ApplicationNote {
  id            String      @id @default(cuid())
  applicationId String
  authorId      String
  body          String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author        User        @relation(fields: [authorId], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  orgId      String
  userId     String?
  role       Role?
  type       String
  subject    String
  body       String
  payload    Json?
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime @default(now())
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, readAt])
}

model Lease {
  id                  String        @id @default(cuid())
  orgId               String
  org                 Org           @relation(fields: [orgId], references: [id])
  unitId              String
  unit                Unit          @relation(fields: [unitId], references: [id])
  startDate           DateTime      @db.Date
  endDate             DateTime      @db.Date
  rentAmountCents     Int
  depositAmountCents  Int
  heldInTrustAccount  Boolean       @default(false)
  paymentDueDay       Int
  state               LeaseState    @default(DRAFT)
  renewedFromId       String?       @unique
  renewedFrom         Lease?        @relation("LeaseRenewal", fields: [renewedFromId], references: [id])
  renewedTo           Lease?        @relation("LeaseRenewal")
  terminatedAt        DateTime?
  terminatedReason    String?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  tenants             LeaseTenant[]
  documents           Document[]
  invoices            Invoice[]
  signatures          LeaseSignature[]
  reviewRequests      LeaseReviewRequest[]

  @@index([orgId, unitId, state])
  @@index([orgId, endDate])
  @@index([orgId, state])
}

model LeaseTenant {
  leaseId    String
  tenantId   String
  isPrimary  Boolean @default(false)
  lease      Lease   @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  @@id([leaseId, tenantId])
  @@index([tenantId])
}

model Document {
  id            String       @id @default(cuid())
  orgId         String
  org           Org          @relation(fields: [orgId], references: [id])
  kind          DocumentKind
  leaseId       String?
  propertyId    String?
  unitId        String?
  tenantId      String?
  filename      String
  mimeType      String
  sizeBytes     Int
  storageKey    String
  uploadedById  String
  uploadedBy    User         @relation("DocumentUploader", fields: [uploadedById], references: [id])
  createdAt     DateTime     @default(now())

  lease         Lease?       @relation(fields: [leaseId], references: [id])
  property      Property?    @relation(fields: [propertyId], references: [id])
  unit          Unit?        @relation(fields: [unitId], references: [id])
  tenant        Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([orgId, leaseId])
  @@index([orgId, tenantId])
}

model MaintenanceRequest {
  id            String              @id @default(cuid())
  orgId         String
  org           Org                 @relation(fields: [orgId], references: [id])
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  unitId        String
  unit          Unit                @relation(fields: [unitId], references: [id])
  title         String
  description   String
  priority      MaintenancePriority @default(MEDIUM)
  status        MaintenanceStatus   @default(OPEN)
  internalNotes String?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([orgId, status])
  @@index([orgId, tenantId])
  @@index([orgId, unitId])
}

model Invoice {
  id              String         @id @default(cuid())
  orgId           String
  org             Org            @relation(fields: [orgId], references: [id])
  leaseId         String
  lease           Lease          @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  periodStart     DateTime       @db.Date
  dueDate         DateTime       @db.Date
  amountCents     Int
  status          InvoiceStatus  @default(DUE)
  paidAt          DateTime?
  paidAmountCents Int?
  paidNote        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([leaseId, periodStart])
  @@index([orgId, status])
  @@index([orgId, dueDate])
}

model LeaseSignature {
  id           String   @id @default(cuid())
  leaseId      String
  lease        Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenantId     String
  signedName   String
  signedAt     DateTime @default(now())
  ipAddress    String?
  userAgent    String?
  latitude     Float?
  longitude    Float?
  locationText String?

  @@unique([leaseId, tenantId])
  @@index([leaseId])
}

model LeaseReviewRequest {
  id             String              @id @default(cuid())
  leaseId        String
  lease          Lease               @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenantId       String
  clauseExcerpt  String
  tenantNote     String
  pmResponse     String?
  status         ReviewRequestStatus @default(OPEN)
  createdAt      DateTime            @default(now())
  respondedAt    DateTime?

  @@index([leaseId, status])
}

model Approval {
  id             String        @id @default(cuid())
  orgId          String
  org            Org           @relation(fields: [orgId], references: [id])
  landlordId     String
  landlord       Landlord      @relation(fields: [landlordId], references: [id])
  propertyId     String?
  kind           ApprovalKind
  subjectType    String?
  subjectId      String?
  payload        Json
  state          ApprovalState @default(PENDING)
  reason         String?
  decisionNote   String?
  requestedById  String
  decidedById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  decidedAt      DateTime?

  @@index([orgId, state])
  @@index([landlordId, state])
  @@index([subjectType, subjectId])
}
